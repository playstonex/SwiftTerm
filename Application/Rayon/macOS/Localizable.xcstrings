    "    if the machine was edited, create a new terminal.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn die Maschine bearbeitet wurde, erstellen Sie ein neues Terminal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "si la máquina fue editada, cree una nueva terminal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "si la machine a été modifiée, créez un nouveau terminal."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マシンが編集されている場合は、新しいターミナルを作成します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "se a máquina foi editada, crie um novo terminal."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "    如果机器信息已修改，请创建一个新的终端。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "    如果機器信息已修改，請創建一個新的終端。"
          }
        }
      }
    },
