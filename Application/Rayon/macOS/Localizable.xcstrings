    "24h trends: %d points, avg CPU %d%%, avg Memory %d%%, avg Disk %d%%": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "24-Stunden-Trends: %d Punkte, durchschnittliche CPU %d%%, durchschnittlicher Speicher %d%%, durchschnittliche Festplatte %d%%"
          }
        },
        "es": {
          "stringUnit": {
