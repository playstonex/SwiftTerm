    "The remote host and port to tunnel to (e.g., Next.js dev server on localhost:3000)": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Remote-Host und der Port, zu dem getunnelt werden soll (z. B. Next.js-Entwicklungsserver auf localhost:3000)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El host remoto y el puerto al que conectarse (por ejemplo, el servidor de desarrollo Next.js en localhost:3000)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'hôte distant et le port vers lesquels créer un tunnel (par exemple, le serveur de développement Next.js sur localhost : 3000)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トンネルするリモート ホストとポート (例: localhost:3000 の Next.js 開発サーバー)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O host remoto e a porta para encapsular (por exemplo, servidor de desenvolvimento Next.js em localhost:3000)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要通过隧道访问的远端主机和端口（例如 localhost:3000 上的 Next.js 开发服务器）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "要通過隧道訪問的遠端主機和端口（例如 localhost:3000 上的 Next.js 開發服務器）"
          }
        }
      }
    },
