        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tendances sur 24 h : %d points, moyenne du processeur %d%%, moyenne de la mémoire %d%%, moyenne du disque %d%%"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "24 時間の傾向: %d ポイント、平均 CPU %d%%、平均メモリ %d%%、平均ディスク %d%%"
