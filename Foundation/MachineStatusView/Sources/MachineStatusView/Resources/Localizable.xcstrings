    "Active & Inactive is not counted as free memory": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiv und inaktiv werden nicht als freier Speicher gezählt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Active & Inactive is not counted as free memory"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activo e inactivo no se cuentan como memoria libre"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Actif et inactif ne sont pas comptés comme mémoire libre"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブおよび非アクティブは空きメモリとしてカウントされません"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativo e Inativo não são contados como memória livre"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Active 和 Inactive 不计入空闲内存"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Active 和 Inactive 不計入空閒內存"
          }
        }
      }
    },
