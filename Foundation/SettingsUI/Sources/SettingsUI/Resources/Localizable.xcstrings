          "stringUnit": {
            "state": "translated",
            "value": "Votre clé API est stockée localement et n'est jamais envoyée à nos serveurs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "API キーはローカルに保存され、当社のサーバーに送信されることはありません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua chave API é armazenada localmente e nunca enviada aos nossos servidores."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
