    "Your API key is stored locally and never sent to our servers.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr API-Schlüssel wird lokal gespeichert und niemals an unsere Server gesendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su clave API se almacena localmente y nunca se envía a nuestros servidores."
          }
        },
